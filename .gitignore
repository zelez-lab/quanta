/target
Cargo.lock
.cargo/config.toml
dist/
libopcodes_complete.rlib

# Verus side-effect build artifacts (`verus --crate-type=lib` drops
# .rlib files in the cwd of the verifier — they're not source).
/lib*.rlib

# Kani per-harness side-effect outputs (run from specs/verify/kani/).
specs/verify/kani/*.rlib
specs/verify/kani/*.out
specs/verify/kani/*.kani-metadata.json
specs/verify/kani/*.pretty_name_map.json
specs/verify/kani/*.type_map.json
specs/verify/kani/*.symtab.json
specs/verify/kani/*kani_metadata*

# Lean build artifacts (specs/verify/lean/)
specs/verify/lean/.lake/
specs/verify/lean/lake-manifest.json
specs/verify/lean/lib*.rlib

# B⁰ web glue build outputs — never committed (regenerated by
# `quanta build web` on every build).
web/dist/
web/node_modules/
examples/web_add_one/*.js
examples/web_add_one/*.wasm
examples/web_triangle/*.js
examples/web_triangle/*.wasm
